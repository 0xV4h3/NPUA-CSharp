@model IEnumerable<Practical9.Models.Student>
@{
    Layout = "_Layout";
}
<h1>Students List</h1>
<a href="/Students/Create">Create new Student</a>
<table>
    <tr>
        <th>Id</th>
        <th>Name</th>
        <th>Age</th>
        <th></th>
    </tr>
    @foreach (var s in Model)
    {
        <tr>
            <td>@s.Id</td>
            <td>@s.Name</td>
            <td>@s.Age</td>
            <td><a href="/Students/Details/@s.Id">Details</a></td>
        </tr>
    }
</table>